generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Document {
  id                  String       @id @default(uuid())
  fileName            String
  fileSize            Int
  mimeType            String
  status              String       @default("uploaded")
  rawText             String?
  extractionConfidence Float?
  parsedData          String?
  reportData          String?
  profileId           String?
  errorMessage        String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  profile             EmployeeProfile? @relation(fields: [profileId], references: [id])
  auditLogs           AuditLog[]
}

model EmployeeProfile {
  id                    String    @id @default(uuid())
  name                  String
  isFullTime            Boolean   @default(true)
  isCadre               Boolean   @default(false)
  weeklyHours           Float     @default(35)
  collectiveAgreement   String?
  contractType          String    @default("CDI")
  bonusVariationMax     Float     @default(20)
  hoursVariationMax     Float     @default(10)
  netGrossRatioMin      Float     @default(0.6)
  netGrossRatioMax      Float     @default(0.85)
  salaryVariationMax    Float     @default(15)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  documents             Document[]
}

model AuditLog {
  id          String   @id @default(uuid())
  documentId  String?
  action      String
  details     String?
  createdAt   DateTime @default(now())

  document    Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
}
